# ==========================================
# FLASK & APPLICATION SETTINGS
# Dependencies: Flask, Werkzeug, itsdangerous
# ==========================================
FLASK_APP=run.py                  # Entry point for your Flask app (or app.py/main.py)
FLASK_DEBUG=1                     # Set to 1 for development, 0 for production
FLASK_ENV=development             # development, production, or testing
SECRET_KEY=your-super-secret-key-here # Required for sessions and itsdangerous
PORT=5000                         # Port for the web server to run on

# ==========================================
# SECURITY & CORS
# Dependencies: flask-cors, bcrypt
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5000 # Comma-separated allowed frontend URLs
BCRYPT_LOG_ROUNDS=12              # Work factor for bcrypt hashing (12-14 is standard)

# ==========================================
# DATABASE SETTINGS
# Dependencies: pymongo, dnspython
# ==========================================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=cyber_ml_database   # Name of your target MongoDB database

# ==========================================
# MACHINE LEARNING & DATA HANDLING
# Dependencies: scikit-learn, joblib, pandas
# ==========================================
MODEL_SAVE_PATH=./models/         # Directory to save/load .joblib ML models
DATA_DIR=./data/                  # Directory for raw or processed datasets (pandas CSVs)

# ==========================================
# CYBERSECURITY & NETWORK MONITORING
# Dependencies: scapy, requests
# ==========================================
NETWORK_INTERFACE=eth0            # Target network interface for Scapy to sniff (e.g., eth0, wlan0, en0)
THREAT_INTEL_API_KEY=your_api_key # Example: If you use 'requests' to fetch external threat feeds

# ==========================================
# REPORTS & VISUALIZATIONS (Admin Reports)
# Dependencies: matplotlib, seaborn
# ==========================================
REPORTS_OUTPUT_DIR=./reports/images/ # Path to save generated charts and dashboards